#!/bin/bash
set -e

# ═══════════════════════════════════════════════════════════════
# Configuration
# ═══════════════════════════════════════════════════════════════

DOTFILES_REPO="https://github.com/kimprap/dotfiles.git"
GITHUB_USER="kimprap"

FONT_NAME="SourceCodePro"
FONT_URL="https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/SourceCodePro.zip"

# Cursor profile UUID (override with CURSOR_PROFILE env var on new machines)
CURSOR_PROFILE="${CURSOR_PROFILE:-344c8ea1}"
CURSOR_USER="$HOME/Library/Application Support/Cursor/User"

# Symlink mappings (source → target)
declare -A SYMLINKS=(
    ["$HOME/.dotfiles/.config/zsh"]="$HOME/.config/zsh"
    ["$HOME/.dotfiles/.config/starship/starship.toml"]="$HOME/.config/starship.toml"
    ["$HOME/.dotfiles/.config/nvim"]="$HOME/.config/nvim"
    ["$HOME/.dotfiles/.config/ghostty"]="$HOME/.config/ghostty"
    ["$HOME/.dotfiles/.config/yazi"]="$HOME/.config/yazi"
    ["$HOME/.dotfiles/.config/cursor/settings.json"]="$CURSOR_USER/profiles/$CURSOR_PROFILE/settings.json"
    ["$HOME/.dotfiles/.config/cursor/keybindings.json"]="$CURSOR_USER/profiles/$CURSOR_PROFILE/keybindings.json"
)

# ═══════════════════════════════════════════════════════════════
# OS & Architecture Detection
# ═══════════════════════════════════════════════════════════════
OS_TYPE="$(uname -s)"

if [[ "$OS_TYPE" == "Darwin" ]]; then
    IS_MACOS=true
else
    IS_MACOS=false
fi


# ═══════════════════════════════════════════════════════════════
# Bootstrap Script
# ═══════════════════════════════════════════════════════════════

echo "🚀 Starting dotfiles bootstrap..."

# ─────────────────────────────────────────────────────────────
# 1. Clone dotfiles repo (if not exists)
# ─────────────────────────────────────────────────────────────
if [[ ! -d "$HOME/.dotfiles/.git" ]]; then
    echo "📁 Cloning dotfiles repository..."
    git clone "$DOTFILES_REPO" "$HOME/.dotfiles"
else
    echo "📁 Dotfiles repository already exists. Skipping clone."
fi

# ─────────────────────────────────────────────────────────────
# 2. Create symlinks
# ─────────────────────────────────────────────────────────────
echo "→ Setting up symlinks..."

mkdir -p "$HOME/.config"
mkdir -p "$CURSOR_USER/profiles/$CURSOR_PROFILE"

for src in "${!SYMLINKS[@]}"; do
    target="${SYMLINKS[$src]}"

    if [[ -L "$target" ]]; then
        echo "   Already symlinked: $target"
    elif [[ -e "$target" ]]; then
        # Backup existing directory/file before overwriting
        backup="${target}.bak.$(date +%Y%m%d-%H%M%S)"
        mv "$target" "$backup"
        echo "   Backed up existing: $target → $backup"
        ln -sfn "$src" "$target"
        echo "   Created symlink: $target → $src"
    else
        ln -sfn "$src" "$target"
        echo "   Created symlink: $target → $src"
    fi
done

# Remove legacy directory symlink (Starship expects a file at ~/.config/starship.toml)
if [[ -L "$HOME/.config/starship" && ! -f "$HOME/.config/starship.toml" ]]; then
    rm "$HOME/.config/starship"
    echo "   Removed legacy ~/.config/starship directory symlink"
fi

# Suppress macOS "Last login: ..." message
touch "$HOME/.hushlogin"

echo "✓ Symlinks setup complete."

# ─────────────────────────────────────────────────────────────
# 2b. Remove stale root-level Cursor settings (profile is canonical)
# ─────────────────────────────────────────────────────────────
STALE_CURSOR_SETTINGS="$CURSOR_USER/settings.json"
if [[ -f "$STALE_CURSOR_SETTINGS" && ! -L "$STALE_CURSOR_SETTINGS" ]]; then
    backup="${STALE_CURSOR_SETTINGS}.bak.$(date +%Y%m%d-%H%M%S)"
    mv "$STALE_CURSOR_SETTINGS" "$backup"
    echo "   Removed stale Cursor settings: $STALE_CURSOR_SETTINGS → $backup"
fi

# ─────────────────────────────────────────────────────────────
# 2c. Minimal ~/.zshrc entry point
# ─────────────────────────────────────────────────────────────
ZSHRC_ENTRY='# Entry point — config is managed in ~/.config/zsh/zshrc (dotfiles)
[[ -f ~/.config/zsh/zshrc ]] && source ~/.config/zsh/zshrc
'

if [[ -f "$HOME/.zshrc" ]] && ! grep -q 'config/zsh/zshrc' "$HOME/.zshrc" 2>/dev/null; then
    backup="$HOME/.zshrc.bak.$(date +%Y%m%d-%H%M%S)"
    cp "$HOME/.zshrc" "$backup"
    echo "   Backed up existing ~/.zshrc → $backup"
fi

if [[ ! -f "$HOME/.zshrc" ]] || ! grep -q 'config/zsh/zshrc' "$HOME/.zshrc" 2>/dev/null; then
    printf '%s' "$ZSHRC_ENTRY" > "$HOME/.zshrc"
    echo "   Wrote minimal ~/.zshrc entry point"
else
    echo "   ~/.zshrc entry point already configured"
fi

# ─────────────────────────────────────────────────────────────
# 3. Install Homebrew (if missing)
# ─────────────────────────────────────────────────────────────
if ! command -v brew &> /dev/null; then
    echo "🍺 Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# ─────────────────────────────────────────────────────────────
# 4. Install required packages
# ─────────────────────────────────────────────────────────────
echo "📦 Installing packages..."

brew install \
    starship \
    antidote \
    yazi \
    fd \
    ripgrep \
    fzf \
    bat \
    jq \
    poppler \
    ffmpegthumbnailer \
    zoxide

# Ghostty is macOS-only
if [[ "$IS_MACOS" == true ]]; then
    brew install --cask ghostty
fi

# ─────────────────────────────────────────────────────────────
# 5. Install Nerd Font
# ─────────────────────────────────────────────────────────────
echo "🔤 Installing Nerd Font ($FONT_NAME)..."


if [[ "$IS_MACOS" == true ]]; then
    FONT_DIR="$HOME/Library/Fonts"
    FONT_ZIP="${FONT_NAME}.zip"

    if [[ ! -f "$FONT_DIR/SauceCodeProNerdFont-Regular.ttf" ]]; then
        curl -fsSL "$FONT_URL" -o "/tmp/$FONT_ZIP"
        unzip -o "/tmp/$FONT_ZIP" -d "$FONT_DIR" "*.ttf"
        rm -f "/tmp/$FONT_ZIP"
        echo "✅ Nerd Font installed."
    else
        echo "✅ Nerd Font already installed. Skipping."
    fi
else
    echo "⏭️  Skipping Nerd Font installation (not on macOS)."
fi

# ─────────────────────────────────────────────────────────────
# 6. Done
# ─────────────────────────────────────────────────────────────
echo ""
echo "✅ Bootstrap complete!"
echo ""
echo "Please restart your terminal to apply changes."

